@namespace eShop.WebAppComponents.Catalog

<div class="star-rating @(Compact ? "star-rating-compact" : "")">
    <div class="stars" role="img" aria-label="@AverageRating.ToString("0.0") out of 5 stars">
        @for (int i = 1; i <= 5; i++)
        {
            var starIndex = i;
            var fillPercentage = GetFillPercentage(starIndex, Interactive ? SelectedRating : AverageRating);

            @if (Interactive)
            {
                <button type="button" class="star-button @(starIndex <= SelectedRating ? "selected" : "")"
                        @onclick="() => OnStarClicked(starIndex)"
                        @onmouseover="() => OnStarHover(starIndex)"
                        @onmouseout="OnStarHoverEnd"
                        aria-label="@starIndex star@(starIndex != 1 ? "s" : "")">
                    <svg width="@Size" height="@Size" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <linearGradient id="star-grad-@_instanceId-@starIndex" x1="0%" y1="0%" x2="100%" y2="0%">
                                <stop offset="@(starIndex <= (HoverRating > 0 ? HoverRating : SelectedRating) ? 100 : 0)%" style="stop-color:#FFB800;stop-opacity:1" />
                                <stop offset="@(starIndex <= (HoverRating > 0 ? HoverRating : SelectedRating) ? 100 : 0)%" style="stop-color:#D1D5DB;stop-opacity:1" />
                            </linearGradient>
                        </defs>
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                              fill="url(#star-grad-@_instanceId-@starIndex)" stroke="#FFB800" stroke-width="1"/>
                    </svg>
                </button>
            }
            else
            {
                <span class="star">
                    <svg width="@Size" height="@Size" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <linearGradient id="star-grad-@_instanceId-@starIndex" x1="0%" y1="0%" x2="100%" y2="0%">
                                <stop offset="@(fillPercentage)%" style="stop-color:#FFB800;stop-opacity:1" />
                                <stop offset="@(fillPercentage)%" style="stop-color:#D1D5DB;stop-opacity:1" />
                            </linearGradient>
                        </defs>
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                              fill="url(#star-grad-@_instanceId-@starIndex)" stroke="#FFB800" stroke-width="1"/>
                    </svg>
                </span>
            }
        }
    </div>
    @if (ShowCount && !Interactive)
    {
        <span class="rating-text">
            @if (ReviewCount > 0)
            {
                <span class="rating-value">@AverageRating.ToString("0.0")</span>
                <span class="rating-count">(@ReviewCount review@(ReviewCount != 1 ? "s" : ""))</span>
            }
            else
            {
                <span class="rating-count">No reviews</span>
            }
        </span>
    }
</div>

@code {
    private static int _globalInstanceCounter;
    private readonly int _instanceId = Interlocked.Increment(ref _globalInstanceCounter);

    [Parameter] public double AverageRating { get; set; }
    [Parameter] public int ReviewCount { get; set; }
    [Parameter] public bool ShowCount { get; set; } = true;
    [Parameter] public bool Compact { get; set; }
    [Parameter] public int Size { get; set; } = 20;
    [Parameter] public bool Interactive { get; set; }
    [Parameter] public int SelectedRating { get; set; }
    [Parameter] public EventCallback<int> SelectedRatingChanged { get; set; }

    private int HoverRating { get; set; }

    private static int GetFillPercentage(int starIndex, double rating)
    {
        if (rating >= starIndex) return 100;
        if (rating <= starIndex - 1) return 0;
        return (int)((rating - (starIndex - 1)) * 100);
    }

    private async Task OnStarClicked(int star)
    {
        SelectedRating = star;
        await SelectedRatingChanged.InvokeAsync(star);
    }

    private void OnStarHover(int star)
    {
        HoverRating = star;
    }

    private void OnStarHoverEnd()
    {
        HoverRating = 0;
    }
}
